# Rename this file to .env and fill in your own values

# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/shoppyglobe

# Port the Express server should run on
PORT=5000

# Secret key used to sign JWT tokens (use a long random string in production)
JWT_SECRET=replace_this_with_a_long_random_secret_key

# JWT expiry duration
JWT_EXPIRES_IN=7d
